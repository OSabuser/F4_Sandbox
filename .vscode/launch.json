{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Remote OpenOCD Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/General.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "external",
            "preLaunchTask": "Docker: Build (Debug)",
            "gdbTarget": "192.168.88.222:2331", // IP удалённой машины
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "device": "STM32F407VE",
            "svdPath": "${workspaceFolder}/STM32F407.svd",
            "interface": "swd",
            // Docker path mapping
            "preLaunchCommands": [
                "set substitute-path /usr/workspace ${workspaceFolder}/",
            ],
        }
    ]
}